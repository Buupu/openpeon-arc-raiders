{
  "cesp_version": "1.0",
  "name": "arc-raiders-emotes",
  "display_name": "Arc Raiders Emotes",
  "version": "1.0.0",
  "description": "Arc Raiders emote voice lines — hey there, let's boogie, don't shoot, and more",
  "author": { "name": "Buupu", "github": "Buupu" },
  "license": "CC-BY-NC-4.0",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [{ "file": "sounds/man-hey-there.mp3", "label": "Hey there" }]
    },
    "task.acknowledge": {
      "sounds": [{ "file": "sounds/man-lets-boogie.mp3", "label": "Let's boogie" }]
    },
    "task.complete": {
      "sounds": [{ "file": "sounds/man-yeah-check-this-out.mp3", "label": "Yeah, check this out" }]
    },
    "task.error": {
      "sounds": [{ "file": "sounds/arc-raiders-deadline.mp3", "label": "Deadline blowing you up" }]
    },
    "input.required": {
      "sounds": [{ "file": "sounds/man-dont-shoot.mp3", "label": "Don't shoot" }]
    },
    "resource.limit": {
      "sounds": [{ "file": "sounds/arc-raiders-lure-grenade.mp3", "label": "Lure Grenade" }]
    }
  }
}
